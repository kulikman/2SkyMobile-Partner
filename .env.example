# ===========================================
# Environment Variables Template
# ===========================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ===========================================

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public URL used in Telegram deep links (set to your prod domain on Vercel)
NEXT_PUBLIC_SITE_URL=https://partnerdev.2skymobile.com

# --- Telegram Bot (optional — admin notifications) ---
# 1. Create a bot via @BotFather → get token
# 2. Add the bot to a group/channel and get the chat ID (use @userinfobot or getUpdates API)
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=-100123456789

# --- Analytics (optional) ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Email (optional) ---
RESEND_API_KEY=re_xxx

# --- AI (optional) ---
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
